@import "/styles/tokens.wxss";

.page {
  min-height: 100vh;
  background: var(--pm-snow);
  color: var(--pm-ink);
  box-sizing: border-box;
}

.hero {
  width: 100%;
  height: 360rpx;
  background: rgba(11, 13, 16, 0.06);
  display: block;
}

.body {
  padding: 32rpx;
  padding-bottom: 80rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
}

.sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--pm-ink-muted, rgba(11, 13, 16, 0.55));
  display: block;
}

.section {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.line {
  font-size: 26rpx;
  line-height: 1.5;
}

.muted {
  font-size: 26rpx;
  color: var(--pm-ink-muted, rgba(11, 13, 16, 0.55));
}

.step {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-top: 8rpx;
}

.step-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: rgba(11, 13, 16, 0.06);
}

.step-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.5;
}

.sub-item {
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid rgba(11, 13, 16, 0.08);
  font-size: 28rpx;
}

.actions {
  margin-top: 40rpx;
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn::after {
  border: none;
}

.btn.primary {
  background: var(--pm-orange);
  color: var(--pm-snow);
}

.btn.ghost {
  background: #fff;
  color: var(--pm-ink);
  border: 1rpx solid rgba(11, 13, 16, 0.16);
}

.disclaimer {
  display: block;
  margin-top: 40rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--pm-ink-muted, rgba(11, 13, 16, 0.55));
}

.state {
  padding: 120rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  align-items: center;
  color: var(--pm-ink-muted, rgba(11, 13, 16, 0.55));
}
