<view class="page">
  <view class="toolbar">
    <button class="today-btn" bindtap="onToday">今日练什么</button>
    <view class="search-row">
      <input
        class="search"
        placeholder="搜索动作名称"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        confirm-type="search"
      />
      <text class="clear-link" wx:if="{{keyword}}" bindtap="clearKeyword">清除</text>
    </view>
  </view>

  <view class="filter-block">
    <text class="filter-label">部位</text>
    <scroll-view scroll-x class="chip-row">
      <view
        wx:for="{{muscleOptions}}"
        wx:key="id"
        class="chip {{primaryMuscle === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onPickMuscle"
      >{{item.labelZh}}</view>
    </scroll-view>
  </view>

  <view class="filter-block">
    <text class="filter-label">器材</text>
    <scroll-view scroll-x class="chip-row">
      <view
        wx:for="{{equipmentOptions}}"
        wx:key="id"
        class="chip {{equipmentId === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onPickEquipment"
      >{{item.labelZh}}</view>
    </scroll-view>
  </view>

  <view class="filter-block">
    <text class="filter-label">难度</text>
    <scroll-view scroll-x class="chip-row">
      <view
        wx:for="{{difficultyOptions}}"
        wx:key="id"
        class="chip {{difficulty === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onPickDifficulty"
      >{{item.labelZh}}</view>
    </scroll-view>
  </view>

  <view class="filter-block">
    <text class="filter-label">目标</text>
    <scroll-view scroll-x class="chip-row">
      <view
        wx:for="{{goalOptions}}"
        wx:key="id"
        class="chip {{goal === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onPickGoal"
      >{{item.labelZh}}</view>
    </scroll-view>
  </view>

  <view class="clear-row" wx:if="{{primaryMuscle || equipmentId || difficulty || goal || keyword}}">
    <text class="clear-link" bindtap="clearFilters">清除全部条件</text>
  </view>

  <view wx:if="{{loading}}" class="state">加载中…</view>
  <view wx:elif="{{error}}" class="state">
    <text>{{error}}</text>
    <button class="retry" bindtap="onRetry">重试</button>
  </view>
  <view wx:elif="{{empty}}" class="state">
    <text>没有符合条件的动作</text>
    <text class="clear-link" bindtap="clearFilters">清除条件</text>
  </view>

  <view wx:else class="list">
    <view
      class="card"
      wx:for="{{items}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="goDetail"
    >
      <image class="cover" src="{{item.coverSrc}}" mode="aspectFill" />
      <view class="card-body">
        <view class="name-row">
          <text class="name">{{item.name}}</text>
          <text wx:if="{{item.collected}}" class="badge">已收藏</text>
        </view>
        <text class="alias" wx:if="{{item.alias}}">{{item.alias}}</text>
        <text class="meta">{{item.primaryMuscleLabel}} · {{item.difficultyLabel}}</text>
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="state muted">加载更多…</view>
  </view>
</view>
