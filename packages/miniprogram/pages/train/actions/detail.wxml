<view class="page">
  <view wx:if="{{loading}}" class="state">加载中…</view>
  <view wx:elif="{{error}}" class="state">
    <text>{{error}}</text>
    <button class="btn" bindtap="onRetry">重试</button>
  </view>

  <block wx:else>
    <image class="hero" src="{{coverSrc}}" mode="aspectFill" />
    <view class="body">
      <text class="title">{{name}}</text>
      <text class="sub">{{difficultyLabel}}</text>

      <view class="section">
        <text class="section-title">基础信息</text>
        <text class="line">所需器材：{{equipmentText}}</text>
        <text class="line">适用场景：{{sceneText}}</text>
      </view>

      <view class="section">
        <text class="section-title">目标肌肉</text>
        <text class="line">主发力肌：{{primaryMusclesText}}</text>
        <text class="line" wx:if="{{secondaryMuscles.length}}">协同肌：{{secondaryMusclesText}}</text>
      </view>

      <view class="section">
        <text class="section-title">动作步骤</text>
        <view class="step" wx:for="{{steps}}" wx:key="*this">
          <image class="step-img" src="{{coverSrc}}" mode="aspectFill" />
          <text class="step-text">{{index + 1}}. {{item}}</text>
        </view>
      </view>

      <view class="section" wx:if="{{cues.length}}">
        <text class="section-title">发力要点</text>
        <text class="line" wx:for="{{cues}}" wx:key="*this">· {{item}}</text>
      </view>

      <view class="section" wx:if="{{mistakes.length}}">
        <text class="section-title">避坑指南</text>
        <text class="line" wx:for="{{mistakes}}" wx:key="*this">· {{item}}</text>
      </view>

      <view class="section" wx:if="{{substitutes.length}}">
        <text class="section-title">替代动作</text>
        <view
          class="sub-item"
          wx:for="{{substitutes}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goSubstitute"
        >{{item.name}}</view>
      </view>
      <view class="section" wx:else>
        <text class="section-title">替代动作</text>
        <text class="muted">暂无替代</text>
      </view>

      <view class="actions">
        <button class="btn ghost" bindtap="onToggleCollect">
          {{collected ? '取消收藏' : '收藏'}}
        </button>
        <button class="btn primary" bindtap="goJoinTraining">加入训练</button>
      </view>

      <text class="disclaimer">{{disclaimer}}</text>
    </view>
  </block>
</view>
