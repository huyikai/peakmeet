@import "/styles/tokens.wxss";

.page {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--pm-snow);
  color: var(--pm-ink);
}

.toolbar {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.today-btn {
  background: var(--pm-orange);
  color: var(--pm-snow);
  border-radius: 12rpx;
  font-size: 28rpx;
}

.today-btn::after {
  border: none;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search {
  flex: 1;
  background: #fff;
  border: 1rpx solid rgba(11, 13, 16, 0.12);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.filter-block {
  margin-bottom: 16rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: var(--pm-ink-muted, rgba(11, 13, 16, 0.55));
  margin-bottom: 8rpx;
}

.chip-row {
  white-space: nowrap;
  width: 100%;
}

.chip {
  display: inline-block;
  margin-right: 12rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 1rpx solid rgba(11, 13, 16, 0.12);
  font-size: 24rpx;
}

.chip.active {
  background: var(--pm-ink);
  color: var(--pm-snow);
  border-color: var(--pm-ink);
}

.clear-row {
  margin: 8rpx 0 20rpx;
}

.clear-link {
  color: var(--pm-orange);
  font-size: 24rpx;
}

.state {
  padding: 80rpx 24rpx;
  text-align: center;
  color: var(--pm-ink-muted, rgba(11, 13, 16, 0.55));
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  align-items: center;
}

.retry {
  background: var(--pm-ink);
  color: var(--pm-snow);
  border-radius: 12rpx;
  font-size: 26rpx;
}

.retry::after {
  border: none;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 48rpx;
}

.card {
  display: flex;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(11, 13, 16, 0.06);
}

.cover {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  background: rgba(11, 13, 16, 0.06);
}

.card-body {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--pm-orange);
  border: 1rpx solid var(--pm-orange);
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
}

.alias {
  font-size: 22rpx;
  color: var(--pm-ink-muted, rgba(11, 13, 16, 0.45));
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  font-size: 24rpx;
  color: var(--pm-ink-muted, rgba(11, 13, 16, 0.55));
}

.state.muted {
  padding: 24rpx 0 8rpx;
  font-size: 24rpx;
}
