/* Shared calculator page styles — imported via each page wxss @import or duplicated lightly */
.page {
  padding: 32rpx 40rpx 80rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.field {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.label {
  color: #666;
  font-size: 24rpx;
}

.input {
  font-size: 30rpx;
}

.sex-row {
  display: flex;
  gap: 16rpx;
}

.sex-btn {
  flex: 1;
  font-size: 26rpx;
  background: #eee;
  color: #333;
}

.sex-btn.active {
  background: #111;
  color: #fff;
}

.mode-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.primary {
  margin-top: 16rpx;
  background: #111;
  color: #fff;
  border-radius: 12rpx;
}

.error {
  color: #b00020;
  margin: 16rpx 0;
  font-size: 26rpx;
}

.result {
  margin-top: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
}

.result-value {
  font-size: 48rpx;
  font-weight: 700;
}

.muted {
  color: #666;
  font-size: 24rpx;
  line-height: 1.5;
}

.block {
  margin-top: 8rpx;
}

.disclaimer {
  margin-top: 32rpx;
  color: #888;
  font-size: 22rpx;
  line-height: 1.5;
}
