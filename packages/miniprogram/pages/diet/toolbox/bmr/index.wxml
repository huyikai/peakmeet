<view class="page">
  <view class="field">
    <text class="label">性别</text>
    <view class="sex-row">
      <button class="sex-btn {{sex === 'male' ? 'active' : ''}}" data-sex="male" bindtap="setSex">男</button>
      <button class="sex-btn {{sex === 'female' ? 'active' : ''}}" data-sex="female" bindtap="setSex">女</button>
    </view>
  </view>
  <view class="field">
    <text class="label">年龄（岁）</text>
    <input class="input" type="number" value="{{age}}" placeholder="例如 25" bindinput="onAge" />
  </view>
  <view class="field">
    <text class="label">身高（cm）</text>
    <input class="input" type="digit" value="{{heightCm}}" placeholder="例如 170" bindinput="onHeight" />
  </view>
  <view class="field">
    <text class="label">体重（kg）</text>
    <input class="input" type="digit" value="{{weightKg}}" placeholder="例如 65" bindinput="onWeight" />
  </view>
  <button class="primary" bindtap="onCalculate">计算</button>
  <text wx:if="{{errorTip}}" class="error">{{errorTip}}</text>

  <view wx:if="{{result}}" class="result">
    <text class="result-title">基础代谢 BMR</text>
    <text class="result-value">{{result.bmrKcal}}</text>
    <text class="result-unit">千卡/日</text>
    <text class="muted">{{result.note}}</text>
    <text class="muted">注意事项：{{notes}}</text>
  </view>
  <text class="disclaimer">{{disclaimer}}</text>
</view>
