.page {
  padding: 32rpx 40rpx 64rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.hero {
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
}

.sub {
  color: #666;
  font-size: 26rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
}

.card-desc {
  color: #666;
  font-size: 24rpx;
}
