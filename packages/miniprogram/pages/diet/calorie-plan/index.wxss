@import "../toolbox/calc-common.wxss";

.section-title {
  margin: 24rpx 0 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.picker {
  font-size: 30rpx;
  padding: 8rpx 0;
  color: #111;
}

.hero {
  border: 2rpx solid #111;
}

.hero-label {
  font-size: 26rpx;
  color: #666;
}

.hero-value {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #111;
}

.hero-unit {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.row {
  font-size: 28rpx;
  color: #222;
  line-height: 1.5;
}

.row.strong {
  font-weight: 600;
}

.macro-block {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin: 8rpx 0;
}

.meal {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.tip-line {
  display: block;
  margin-bottom: 8rpx;
}

.risk {
  margin-top: 12rpx;
  color: #8a4b08;
  background: #fff6e8;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.warn {
  color: #8a4b08;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}
